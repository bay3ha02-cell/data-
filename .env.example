# ==============================================
# ملف متغيرات البيئة (Environment Variables)
# انسخ هذا الملف باسم .env وعدّل القيم حسب بيئتك
# لا يتم رفع ملف .env الحقيقي إلى Git أبداً
# ==============================================

# ----- إعدادات الخادم العامة -----
PORT=5000
NODE_ENV=development

# ----- قاعدة البيانات MongoDB -----
# مثال محلي: mongodb://localhost:27017/team_challenge_db
# مثال Atlas: mongodb+srv://user:password@cluster.mongodb.net/team_challenge_db
MONGO_URI=mongodb://localhost:27017/team_challenge_db

# ----- إعدادات JWT (المصادقة) -----
JWT_SECRET=ضع_هنا_مفتاح_سري_طويل_وعشوائي_جداً
JWT_EXPIRES_IN=7d

# ----- إعدادات Stripe (الدفع) -----
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ----- إعدادات أخرى -----
# رابط الواجهة الأمامية (يُستخدم في CORS وروابط الدفع)
CLIENT_URL=http://localhost:3000
